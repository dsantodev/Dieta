# 1. Ambiente virtuale
venv/
.venv/

# 2. File compilati di Python e cache
__pycache__/
*.py[cod] 
# È un modo contratto per dire a Git di ignorare tutti i file con estensione .pyc, .pyo o .pyd.
*$py.class

# 3. Chiavi di accesso e variabili d'ambiente
env/
.env

# 4. (Opzionale) Configurazione dell'editor
.vscode/
.idea/

# 5. File di sistema
.DS_Store
Thumbs.db

# 6. Trick per preservare la strittuta ma ignorare il contenuto della cartella
# Ignora Cartella e tutto il contenuto...
resources/*
# ...ma tieni traccia dei file .gitkeep (preserva la struttura)
!**/resources/.gitkeep
